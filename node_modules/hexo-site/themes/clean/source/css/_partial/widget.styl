.tagcloud a {
  display: inline-block;
  margin: 5px 5px 0 0;
}

[data-theme='dark'] .widget-wrap {
  box-shadow: 0px 0px 20px 1px #ffbb763f;
}

.widget-wrap {
  margin: 40px 0 0 0;
  background-color: var(--glass-card-bg);
  border: 1px solid rgba(255, 255, 255, 0.222);
  border-radius: 0.7rem;
  transition: all ease 0.3s;
  box-shadow: none;
  backdrop-filter: blur(var(--glass-card-blur)) saturate(var(--glass-card-saturate));
  -webkit-backdrop-filter: blur(var(--glass-card-blur)) saturate(var(--glass-card-saturate));
  position: relative;
  overflow: hidden;

  &:before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.1), rgba(255, 187, 118, 0.1) 48%, rgba(255, 255, 255, 0.04));
  }

  > * {
    position: relative;
    z-index: 1;
  }

  &:hover {
    box-shadow: 0px 0px 20px 1px #ffbb763f;
    border-color: rgba(255, 255, 255, 0.454);
  }
}

.widget-wrapper {
  transition: 0.3s;

  .aos-animate {
    transition-property: initial !important;

    &:hover {
      box-shadow: 0px 0px 20px 1px #ffbb763f;
      border-color: rgba(255, 255, 255, 0.454);
    }
  }
}

.widget-title {
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--glass-card-title);
  padding: 20px 20px 8px;
  font-weight: var(--glass-card-font-weight);
}

.widget {
  color: var(--glass-card-text);
  padding: 4px 20px 20px;

  li {
    color: var(--glass-card-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  a, span {
    color: var(--glass-card-text);
    text-decoration: none;
    opacity: 0.9;
    transition: 0.3s;

    &:hover {
      opacity: 1;
      color: var(--glass-card-title);
    }
  }

  span {
    margin-left: 5px;
  }

  ul, ol, dl {
    ul, ol, dl {
      margin-left: 16px;
      list-style: none;
    }
  }

  li {
    margin-top: 4px;
    line-height: normal;

    &:before {
      content: '';
      display: inline-block;
      width: 5px;
      height: 10px;
      background: var(--color-h2-after);
      vertical-align: middle;
      margin-right: 12px;
      box-shadow: var(--shadow-red-6-shadow);
      opacity: 0.5;
      transition: 0.3s;
    }

    &:hover:before {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      opacity: 1;
    }
  }
}
