.custom-block {
  margin: 28px 0;
  border-radius: 0.7rem;
  transition: all ease 0.3s;
  display: flow-root;
  padding: 8px 18px;
  border: 1px solid rgba(255, 255, 255, 0.222);
  box-shadow: none;
  backdrop-filter: blur(var(--glass-card-blur)) saturate(var(--glass-card-saturate));
  -webkit-backdrop-filter: blur(var(--glass-card-blur)) saturate(var(--glass-card-saturate));

  &:hover {
    box-shadow: 0px 0px 20px 1px #ffbb763f;
    border-color: rgba(255, 255, 255, 0.454);
  }

  .custom-block-title:before {
    font-weight: normal;
    margin-right: 8px;

    if (hexo-config('icon_font')) {
      font-family: font-icon;
    } else {
      font-family: var(--font-icon);
    }
  }

  &.info {
    background: linear-gradient(180deg, unquote('color-mix(in srgb, var(--color-info-bg) 94%, transparent)') 0%, unquote('color-mix(in srgb, var(--color-background) 72%, transparent)') 100%);
    color: var(--color-info-text);
    border-color: unquote('color-mix(in srgb, var(--color-info-text) 18%, transparent)');
    box-shadow: 0 16px 34px unquote('color-mix(in srgb, var(--color-info-text) 10%, transparent)');

    .custom-block-title:before {
      if (hexo-config('icon_font')) {
        content: '\e647';
      } else {
        content: '\f05a';
      }
    }
  }

  &.warning {
    background: linear-gradient(180deg, unquote('color-mix(in srgb, var(--color-warning-bg) 94%, transparent)') 0%, unquote('color-mix(in srgb, var(--color-background) 72%, transparent)') 100%);
    color: var(--color-warning-text);
    border-color: unquote('color-mix(in srgb, var(--color-warning-text) 18%, transparent)');
    box-shadow: 0 16px 34px unquote('color-mix(in srgb, var(--color-warning-text) 10%, transparent)');

    .custom-block-title:before {
      if (hexo-config('icon_font')) {
        content: '\e646';
      } else {
        content: '\f06a';
      }
    }
  }

  &.danger {
    background: linear-gradient(180deg, unquote('color-mix(in srgb, var(--color-danger-bg) 94%, transparent)') 0%, unquote('color-mix(in srgb, var(--color-background) 72%, transparent)') 100%);
    color: var(--color-danger-text);
    border-color: unquote('color-mix(in srgb, var(--color-danger-text) 18%, transparent)');
    box-shadow: 0 16px 34px unquote('color-mix(in srgb, var(--color-danger-text) 10%, transparent)');

    .custom-block-title:before {
      if (hexo-config('icon_font')) {
        content: '\e645';
      } else {
        content: '\f057';
        font-weight: 900;
      }
    }
  }

  &.tip {
    background: linear-gradient(180deg, unquote('color-mix(in srgb, var(--color-tip-bg) 94%, transparent)') 0%, unquote('color-mix(in srgb, var(--color-background) 72%, transparent)') 100%);
    color: var(--color-tip-text);
    border-color: unquote('color-mix(in srgb, var(--color-tip-text) 18%, transparent)');
    box-shadow: 0 16px 34px unquote('color-mix(in srgb, var(--color-tip-text) 10%, transparent)');

    .custom-block-title:before {
      if (hexo-config('icon_font')) {
        content: '\e643';
      } else {
        content: '\f058';
        font-weight: 900;
      }
    }
  }

  &.important {
    background: linear-gradient(180deg, unquote('color-mix(in srgb, var(--color-important-bg) 94%, transparent)') 0%, unquote('color-mix(in srgb, var(--color-background) 72%, transparent)') 100%);
    color: var(--color-important-text);
    border-color: unquote('color-mix(in srgb, var(--color-important-text) 18%, transparent)');
    box-shadow: 0 16px 34px unquote('color-mix(in srgb, var(--color-important-text) 10%, transparent)');

    .custom-block-title:before {
      if (hexo-config('icon_font')) {
        content: '\e649';
      } else {
        content: '\f192';
        font-weight: 900;
      }
    }
  }

  p {
    margin: 12px 0;
  }
}

.custom-block-title {
  margin: 12px 0 !important;
  font-size: 18px;
  font-weight: 700;
}

[data-theme='dark'] {
  &:root {
    --color-info-bg: hsl(210, 30%, 25%);
    --color-info-text: hsl(210, 80%, 70%);
    --color-info-shadow: hsl(210, 30%, 16%);
    --color-warning-bg: hsl(40, 30%, 25%);
    --color-warning-text: hsl(40, 80%, 70%);
    --color-warning-shadow: hsl(40, 30%, 16%);
    --color-danger-bg: hsl(0, 30%, 25%);
    --color-danger-text: hsl(0, 80%, 70%);
    --color-danger-shadow: hsl(0, 30%, 16%);
    --color-tip-bg: hsl(138, 30%, 25%);
    --color-tip-text: hsl(138, 80%, 70%);
    --color-tip-shadow: hsl(138, 30%, 16%);
    --color-important-bg: hsl(270, 30%, 25%);
    --color-important-text: hsl(270, 80%, 70%);
    --color-important-shadow: hsl(270, 30%, 16%);
  }
}
