.popup {
  visibility: hidden;
  position: fixed;
  top: 8%;
  left: 50%;
  width: 760px;
  max-height: 82%;
  margin-left: -380px;
  background: linear-gradient(180deg, unquote('color-mix(in srgb, var(--color-wrap) 92%, transparent)') 0%, unquote('color-mix(in srgb, var(--color-background) 68%, transparent)') 100%);
  color: var(--grey-9);
  z-index: 9999;
  border-radius: 28px;
  opacity: 0;
  transform: scale(0.5);
  transition: 0.3s;
  box-shadow: 0 28px 64px unquote('color-mix(in srgb, var(--color-meta-shadow) 86%, transparent)');
  backdrop-filter: blur(26px) saturate(136%);
  -webkit-backdrop-filter: blur(26px) saturate(136%);
  border: 1px solid unquote('color-mix(in srgb, var(--red-3) 20%, transparent)');
  overflow: hidden;

  &.show {
    visibility: visible;
    opacity: 1;
    transform: scale(1);
  }

  @media mg-normal {
    top: 0;
    left: 0;
    margin: 0;
    width: 100%;
    height: 100%;
    border-radius: 0;
    max-height: 100%;
  }

  @media mq-normal {
    min-height: 350px;
  }
}

.reimu-popup {
  overflow: hidden;
  padding: 0;
  display: flex;
  flex-direction: column;
}

.popup-btn-close {
  color: var(--red-1);
  font: 20px bold;
  cursor: var(--cursor-pointer) !important;
  padding-left: 8px;
  transition: 0.3s;

  &:hover {
    opacity: 0.8;
  }
}

.reimu-search {
  display: flex;
  align-items: center;
  padding: 14px 18px;
  border-bottom: 1px solid unquote('color-mix(in srgb, var(--red-3) 16%, transparent)');
  flex-shrink: 0;
  background: unquote('color-mix(in srgb, var(--color-background) 34%, transparent)');
  box-shadow: inset 0 -1px 0 unquote('color-mix(in srgb, var(--red-3) 10%, transparent)');
}

.reimu-search-input-icon {
  display: inline-block;
  width: 20px;
  font-size: 18px;
  vertical-align: middle;
  margin-right: 8px;
}

#reimu-search-input {
  flex: 1;

  input {
    width: 100%;
    outline: none;
    border: none;
    background: transparent;
    color: var(--grey-9);
    font-size: 16px;
    vertical-align: middle;
    font-family: font-basic;
  }

  input::placeholder {
    color: var(--grey-7);
  }

  input[type=search]::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }
}

.reimu-powered {
  float: right;
  cursor: var(--cursor-default) !important;

  img {
    display: inline-block;
    height: 18px;
    vertical-align: middle;
  }
}

.reimu-results {
  position: relative;
  overflow: auto;
  padding: 20px 24px 24px;
  box-sizing: border-box;

  hr {
    margin: 16px 0 8px 0;
    border: none;
    height: 1px;
    background: unquote('color-mix(in srgb, var(--red-3) 16%, transparent)');
  }
}

#reimu-hits {
  margin-top: 12px;

  mark {
    background: var(--red-1);
    color: #fff;
  }
}

.reimu-hit-item-link {
  display: block;
  text-decoration: none;
  color: var(--red-2);
  padding: 14px 16px 14px 26px;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
  border-radius: 18px;
  transition: background 0.2s, transform 0.2s, color 0.2s, box-shadow 0.2s;

  &:before {
    content: '';
    width: 6px;
    height: 12px;
    background: var(--color-h2-after);
    display: inline-block;
    vertical-align: middle;
    margin: -2px 12px 0 -18px;
    box-shadow: var(--shadow-red-6-shadow);
    opacity: 0.5;
    transition: 0.2s;
  }

  &:hover, &:focus {
    background: unquote('color-mix(in srgb, var(--red-6) 84%, transparent)');
    transform: translateX(2px);
    box-shadow: inset 0 0 0 1px unquote('color-mix(in srgb, var(--red-3) 16%, transparent)');
  }

  &:hover:before, &:focus:before {
    height: 6px;
    border-radius: 50%;
    opacity: 1;
  }
}

.reimu-pagination {
  margin: 14px auto 6px;
  text-align: center;
  color: var(--grey-9);
  overflow: hidden;

  a {
    padding: 10px 16px;
    color: var(--grey-9);
    text-decoration: none;
    transition: 0.2s;

    &:hover, &:focus {
      background: linear-gradient(135deg, var(--red-1), var(--red-2));
      box-shadow: 0 10px 24px unquote('color-mix(in srgb, var(--color-red-3-shadow) 38%, transparent)');
      color: #fff;
    }
  }

  .pagination-item {
    display: inline-block;
  }

  .page-number {
    display: inline-block;
    border-radius: 999px;
    margin: 6px;
    background: unquote('color-mix(in srgb, var(--color-background) 42%, transparent)');
  }

  .current {
    .page-number {
      color: #fff;
      background: linear-gradient(135deg, var(--red-1), var(--red-2));
      font-weight: 700;
      box-shadow: 0 10px 24px unquote('color-mix(in srgb, var(--color-red-3-shadow) 38%, transparent)');
    }
  }

  .disabled-item {
    display: none;
  }
}

.reimu-bg {
  position: absolute;
  right: 0;
  bottom: 0;
  z-index: -1;
  opacity: 0.5;
}

#reimu-hits-empty {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}