#comments {
  background: linear-gradient(180deg, unquote('color-mix(in srgb, var(--color-wrap) 92%, transparent)') 0%, unquote('color-mix(in srgb, var(--color-background) 64%, transparent)') 100%);
  backdrop-filter: blur(24px) saturate(132%);
  -webkit-backdrop-filter: blur(24px) saturate(132%);
  padding: article-padding article-padding + 16px;
  border-radius: post-radius;
  margin: 18px 0;
  border: 1px solid unquote('color-mix(in srgb, var(--red-3) 24%, transparent)');
  box-shadow: 0 24px 55px unquote('color-mix(in srgb, var(--color-meta-shadow) 72%, transparent)');
  position: relative;
  overflow: hidden;

  &:before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, transparent 0%, unquote('color-mix(in srgb, var(--color-background) 12%, transparent)') 56%, transparent 100%);
    opacity: 0.52;
  }

  > * {
    position: relative;
    z-index: 1;
  }

  &:hover {
    box-shadow: 0 30px 68px unquote('color-mix(in srgb, var(--color-meta-shadow) 85%, transparent)');
  }

  @media mg-normal {
    padding: article-padding 16px;
  }

  a {
    color: var(--color-link);
  }

  .comment-header {
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 12px;
    margin-bottom: 18px;

    .comment-title {
      margin: 0;
      width: 100%;
      text-align: center;
      color: var(--color-default);
      font-size: 30px;
      letter-spacing: 1px;
      text-shadow: 0 10px 30px unquote('color-mix(in srgb, var(--color-meta-shadow) 35%, transparent)');
    }

    .comment-selector {
      width: 100%;
      display: flex;
      justify-content: center;
      margin-bottom: 0;
    }

    .comment-selector-wrap {
      display: inline-flex;
      overflow: hidden;
      border-radius: 999px;
      padding: 8px;
      gap: 8px;
      background: unquote('color-mix(in srgb, var(--color-background) 48%, transparent)');
      box-shadow: inset 0 0 0 1px unquote('color-mix(in srgb, var(--red-3) 20%, transparent)'), 0 12px 28px unquote('color-mix(in srgb, var(--color-red-3-shadow) 28%, transparent)');

      .selector-item {
        font-size: 14px;
        color: var(--color-default);
        background-color: transparent;
        transition: 0.3s;
        padding: 10px 16px;
        cursor: var(--cursor-pointer) !important;
        font-weight: 700;
        border-radius: 999px;
        letter-spacing: 0.4px;

        span {
          cursor: var(--cursor-pointer) !important;
        }

        &:hover {
          background-color: unquote('color-mix(in srgb, var(--red-5) 68%, transparent)');
          color: var(--red-1);
        }

        &.active {
          color: #fff;
          background: linear-gradient(135deg, var(--red-1), var(--red-2));
          box-shadow: 0 10px 24px unquote('color-mix(in srgb, var(--color-red-3-shadow) 55%, transparent)');
        }
      }
    }
  }

  .comment-content {
    > .comment {
      background: linear-gradient(180deg, unquote('color-mix(in srgb, var(--color-background) 54%, transparent)') 0%, unquote('color-mix(in srgb, var(--color-wrap) 82%, transparent)') 100%);
      border-radius: post-radius;
      padding: 18px;
      box-shadow: inset 0 0 0 1px unquote('color-mix(in srgb, var(--red-4) 22%, transparent)'), 0 18px 40px unquote('color-mix(in srgb, var(--color-meta-shadow) 34%, transparent)');
    }
  }
}

if (has-waline) {
  .wl-emoji-popup {
    max-width: calc(100vw - 90px) !important;
  }

  .wl-count, .wl-header label, .wl-empty, .wl-info {
    color: var(--color-default) !important;
  }

  .wl-header input {
    font-size: revert !important;
  }

  .wl-panel {
    margin: 1em 0 !important;
    background: transparent !important;
  }

  .wl-action, .wl-sort li, .wl-login-info, .wl-emoji-popup, .wl-input, .wl-card {
    cursor: var(--cursor-pointer) !important;
  }

  .wl-card {
    border-radius: 22px !important;
    padding: 16px 18px !important;
    margin: 18px 0 !important;
    border: 1px solid unquote('color-mix(in srgb, var(--red-3) 18%, transparent)') !important;
    background: linear-gradient(180deg, unquote('color-mix(in srgb, var(--color-wrap) 88%, transparent)') 0%, unquote('color-mix(in srgb, var(--color-background) 58%, transparent)') 100%) !important;
    box-shadow: 0 18px 40px unquote('color-mix(in srgb, var(--color-meta-shadow) 30%, transparent)') !important;
  }

  .wl-editor, .wl-input, .wl-preview {
    border-radius: 18px !important;
    background: unquote('color-mix(in srgb, var(--color-background) 48%, transparent)') !important;
    box-shadow: inset 0 0 0 1px unquote('color-mix(in srgb, var(--red-4) 22%, transparent)') !important;
  }

  .wl-header, .wl-actions, .wl-meta, .wl-content {
    color: var(--color-default) !important;
  }

  .wl-avatar img {
    border-radius: 16px !important;
    box-shadow: 0 10px 24px unquote('color-mix(in srgb, var(--color-meta-shadow) 30%, transparent)') !important;
  }

  .wl-btn, .wl-login-link {
    border-radius: 999px !important;
    border: none !important;
    background: linear-gradient(135deg, var(--red-1), var(--red-2)) !important;
    color: #fff !important;
    box-shadow: 0 10px 24px unquote('color-mix(in srgb, var(--color-red-3-shadow) 45%, transparent)') !important;
  }
}

if (has-valine) {
  .vcontent {
    padding-left: 10px;
    padding-right: 10px;
  }

  .v[data-class='v'] .vwrap, .v[data-class='v'] .vcards .vcard {
    border-radius: 22px !important;
    border: 1px solid unquote('color-mix(in srgb, var(--red-3) 18%, transparent)') !important;
    background: linear-gradient(180deg, unquote('color-mix(in srgb, var(--color-wrap) 88%, transparent)') 0%, unquote('color-mix(in srgb, var(--color-background) 58%, transparent)') 100%) !important;
    box-shadow: 0 18px 40px unquote('color-mix(in srgb, var(--color-meta-shadow) 30%, transparent)') !important;
  }

  .v[data-class='v'] .vwrap {
    padding: 14px !important;
  }

  .v[data-class='v'] .vinput, .v[data-class='v'] .vpreview {
    border-radius: 16px !important;
    background: unquote('color-mix(in srgb, var(--color-background) 48%, transparent)') !important;
  }

  .v[data-class='v'] .vbtn {
    border: none !important;
    border-radius: 999px !important;
    background: linear-gradient(135deg, var(--red-1), var(--red-2)) !important;
    color: #fff !important;
    box-shadow: 0 10px 24px unquote('color-mix(in srgb, var(--color-red-3-shadow) 45%, transparent)') !important;
  }

  [data-theme='dark'] .v[data-class='v'] .vcards .vcard .vcontent.expand::after, .dark .v[data-class='v'] .vcards .vcard .vcontent.expand::after, .theme__dark .v[data-class='v'] .vcards .vcard .vcontent.expand::after, .night .v[data-class='v'] .vcards .vcard .vcontent.expand::after {
    background: var(--color-wrap) !important;
  }

  [data-theme='dark'] .v[data-class='v'] .vcards .vcard .vcontent.expand::before, .dark .v[data-class='v'] .vcards .vcard .vcontent.expand::before, .theme__dark .v[data-class='v'] .vcards .vcard .vcontent.expand::before, .night .v[data-class='v'] .vcards .vcard .vcontent.expand::before {
    --valine-linear-gradient-color: unquote('color-mix(in srgb, var(--color-wrap) 10%, transparent)');
    background: linear-gradient(180deg, var(--valine-linear-gradient-color), var(--color-wrap)) !important;
  }

  .v[data-class='v'] .vcards .vcard .vh .vmeta .vat {
    color: var(--red-1) !important;
  }
}

if (has-giscus) {
  .giscus-comment {
    width: auto;
    min-height: 220px;
    padding: 6px;
    border-radius: 22px;
    background: linear-gradient(180deg, unquote('color-mix(in srgb, var(--color-background) 52%, transparent)') 0%, unquote('color-mix(in srgb, var(--color-wrap) 82%, transparent)') 100%);
    box-shadow: inset 0 0 0 1px unquote('color-mix(in srgb, var(--red-4) 18%, transparent)');
  }

  .giscus-comment iframe {
    border-radius: 18px;
    background: transparent;
  }
}

if (has-gitalk) {
  .gitalk-comment {
    color: var(--color-default);
  }

  .gt-container .gt-meta, .gt-container .gt-comments-null, .gt-container .gt-header-textarea, .gt-container .gt-svg svg {
    color: var(--color-default) !important;
    fill: currentColor !important;
  }

  .gt-header-comment .gt-header-preview.markdown-body, .gt-comment-content .gt-comment-body.markdown-body {
    h2, h1 {
      border-bottom: none;
    }

    table {
      display: table;
    }

    table tr {
      background-color: transparent !important;
      border: none;
    }

    table th {
      border: none;
      border-bottom: 3px solid var(--color-border);
    }

    table td {
      border: none;
      border-bottom: 1px solid var(--color-border);
    }
  }

  .gt-header-textarea {
    background: unquote('color-mix(in srgb, var(--color-background) 52%, transparent)') !important;
    color: var(--color-default) !important;
    border-radius: 18px !important;
  }

  .gt-container .gt-header-comment {
    width: 100%;
  }

  .gt-container .gt-header-preview, .gt-container .gt-comment-content, .gt-container .gt-popup, .gt-container .gt-header-textarea, .gt-container .gt-btn-preview, .gt-container .gt-btn-login, .gt-container .gt-btn-public {
    border-radius: 20px !important;
  }

  .gt-container .gt-header-preview, .gt-container .gt-comment-content, .gt-container .gt-popup {
    background: linear-gradient(180deg, unquote('color-mix(in srgb, var(--color-wrap) 88%, transparent)') 0%, unquote('color-mix(in srgb, var(--color-background) 58%, transparent)') 100%) !important;
    border: 1px solid unquote('color-mix(in srgb, var(--red-3) 18%, transparent)') !important;
    box-shadow: 0 18px 40px unquote('color-mix(in srgb, var(--color-meta-shadow) 30%, transparent)') !important;
  }

  .gt-container .gt-comment-content {
    &:hover {
      box-shadow: 0 22px 48px unquote('color-mix(in srgb, var(--color-meta-shadow) 36%, transparent)') !important;
    }
  }

  .gt-container .gt-avatar img {
    border-radius: 16px !important;
    box-shadow: 0 10px 24px unquote('color-mix(in srgb, var(--color-meta-shadow) 24%, transparent)') !important;
  }

  .gt-container .gt-action, .gt-container .gt-btn-preview, .gt-container .gt-btn-login, .gt-container .gt-btn-public, .gt-container .gt-svg {
    transition: transform 0.2s, color 0.2s, opacity 0.2s;
  }

  .gt-container .gt-action:hover, .gt-container .gt-btn-preview:hover, .gt-container .gt-btn-login:hover, .gt-container .gt-btn-public:hover {
    transform: translateY(-1px);
  }

  .gt-container .gt-btn {
    border: none !important;
    background: linear-gradient(135deg, var(--red-1), var(--red-2)) !important;
    color: #fff !important;
    box-shadow: 0 10px 24px unquote('color-mix(in srgb, var(--color-red-3-shadow) 45%, transparent)') !important;
  }
}

$base-comment-style {
  color: var(--color-default) !important;
  @extend $base-style;

  p, table {
    line-height: line-height;
    margin: 16px 0;
  }

  h1, h2, h3, h4, h5, h6 {
    font-weight: bold;
    line-height: line-height-title;
    margin: line-height-title 0 0.75em;
  }

  h2 {
    margin-bottom: 40px;
  }

  a {
    color: var(--color-link);
    text-decoration: none;
    word-break: break-word;

    &:hover {
      text-decoration: underline;
    }
  }

  li {
    margin: 8px 0;

    &:hover {
      &::marker {
        transition: color 0.2s;
        color: var(--red-1);
      }
    }
  }

  img, video {
    max-width: 100%;
    height: auto;
    display: block;
    margin: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    border-spacing: 0;
  }

  th {
    font-weight: bold;
    border-bottom: 3px solid var(--color-border);
    padding-bottom: 8px;
  }

  td {
    border-bottom: 1px solid var(--color-border);
    padding: 8px 0;
  }

  blockquote {
    background: var(--red-5-5);
    border-left: 6px var(--red-4) solid !important;
    margin: 28px 0 !important;
    border-radius: post-radius;
    transition: 0.3s;
    display: flow-root;
    padding: 0 12px !important;
    box-shadow: var(--shadow-meta);

    &:hover {
      box-shadow: var(--shadow-meta-hover);
    }

    footer {
      font-size: font-size;
      margin: 24px 0;

      cite {
        &:before {
          content: '—';
          padding: 0 8px;
        }
      }
    }
  }

  details {
    padding: 16px 12px;
    border-radius: post-radius;
    background-color: var(--red-5-5);
    box-shadow: var(--shadow-meta);
    transition: 0.3s;

    &:hover {
      box-shadow: var(--shadow-meta-hover);
    }
  }

  summary {
    font-size: 1.1em;
    font-weight: bold;
    cursor: var(--cursor-pointer) !important;
    padding: 8px;
    border: none;
    border-radius: tag-radius;
    transition: 0.3s;
  }

  summary:hover {
    background-color: var(--red-5);
  }

  details[open] summary {
    background-color: var(--red-5);
  }

  details[open] summary:hover {
    background-color: var(--red-5);
  }

  details p {
    margin: 20px 0 0;
    padding: 12px;
    background-color: var(--color-footer-background);
    border-radius: tag-radius;
    transition: 0.3s;
  }

  hr {
    border-style: none !important;
    background-color: transparent !important;
  }

  pre, code {
    font-family: $font-code !important;
    font-size: 93.75% !important;
    transition: 0.3s;
    word-break: break-word;
  }

  code:not(pre code) {
    background: var(--color-code-background) !important;
    padding: 1px 4px !important;
    border-radius: 6px !important;
    color: var(--color-link) !important;
  }
}

if (has-waline) {
  .wl-content {
    @extend $base-comment-style;
  }
}

if (has-valine) {
  .vcontent {
    @extend $base-comment-style;
  }
}

if (has-gitalk) {
  .gt-header-preview.markdown-body, .gt-comment-content .gt-comment-body.markdown-body {
    @extend $base-comment-style;
  }
}
