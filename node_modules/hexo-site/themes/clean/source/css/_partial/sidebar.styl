$menu-link {
  color: var(--glass-card-text);
  opacity: 1;
  text-decoration: none;
  transition: opacity 0.2s, color 0.2s;
  display: block;
  padding: 10px 15px;
  font-weight: var(--glass-card-font-weight);
  letter-spacing: 0.1em;
}

.sidebar-menu {
  margin: 14px 0 20px;
  width: 100%;
}

.sidebar-menu-link-wrap {
  display: flex;
  position: relative;
  width: calc(100% - 40px);
  max-width: none;
  margin: 10px 20px;
  justify-content: flex-start;
  align-items: center;
  border: 1px solid rgba(255, 255, 255, 0.222);
  border-radius: 0.7rem;
  background-color: var(--glass-card-bg);
  box-shadow: none;
  transition: all ease 0.3s;

  &:hover {
    border-color: rgba(255, 255, 255, 0.454);
    box-shadow: 0px 0px 20px 1px #ffbb763f;
    transform: translateY(-2px);
  }

  &:hover .sidebar-menu-icon:before {
    transform: rotate(90deg) scale(1.1);
  }

  &:hover .sidebar-menu-icon {
    transform: scale(1.06);
  }

  &:hover .sidebar-menu-icon.rotate {
    transform: rotate(90deg) scale(1.06);
  }
}

.sidebar-menu-icon {
  @extend $menu-link;
  font-size: 24px;
  font-weight: 400;
  transition: transform 0.3s, background 0.5s, color 0.5s;
  will-change: transform;

  &:before {
    font-size: 24px;
    font-weight: 400;
    transform: rotate(90deg);
    transition: transform 0.3s;
    will-change: transform;
  }

  &.rotate {
    transform: rotate(90deg);
  }

  pointer-events: none;
  padding: 12px 10px 12px 16px;
  display: flex;
  align-items: center;
}

.sidebar-menu-link-dummy {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
}

.sidebar-menu-link {
  @extend $menu-link;
  pointer-events: none;
  padding: 12px 16px 12px 0;
  flex: 1;
}

.link-active {
  background-color: rgba(255, 187, 118, 0.16);
  border: 1px solid rgba(255, 255, 255, 0.454);
  box-shadow: 0px 0px 20px 1px #ffbb763f;
  opacity: 1;

  &:hover {
    opacity: 1;
  }

  .sidebar-menu-link {
    color: var(--glass-card-title);
    opacity: 1;
  }

  .sidebar-menu-icon {
    opacity: 1;
    color: var(--glass-card-title);
  }
}

.sidebar-toc-wrapper {
  color: var(--glass-card-text);
  flex: 1;
  min-height: 0;
  overflow: auto;
  margin: 0 16px 18px;
  padding: 16px 18px 20px;
  border-radius: 0.7rem;
  background-color: var(--glass-card-bg);
  border: 1px solid rgba(255, 255, 255, 0.222);
  box-shadow: none;
  backdrop-filter: blur(var(--glass-card-blur)) saturate(var(--glass-card-saturate));
  -webkit-backdrop-filter: blur(var(--glass-card-blur)) saturate(var(--glass-card-saturate));
  transition: all ease 0.3s;

  &:hover {
    box-shadow: 0px 0px 20px 1px #ffbb763f;
    border-color: rgba(255, 255, 255, 0.454);
  }

  &::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  a, span {
    color: var(--glass-card-text);
    text-decoration: none;
    opacity: 0.82;
    transition: 0.3s;

    &:hover {
      color: var(--glass-card-title);
    }
  }

  & ol {
    margin-left: 16px;
    list-style: none;
  }

  > ol {
    margin-left: 0;
  }

  & li {
    margin: 8px 0;
    padding: 1px 0;

    &:before {
      content: '';
      width: 5px;
      height: 10px;
      background: var(--color-h2-after);
      display: inline-block;
      vertical-align: middle;
      margin-right: 12px;
      box-shadow: var(--shadow-red-6-shadow);
      opacity: 0.5;
      transition: 0.3s;
    }

    &:hover {
      &:before {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        opacity: 1;
      }
    }
  }

  .toc-level-1 {
    list-style: none;

    &:before {
      display: none;
    }

    >a {
      width: 100%;
      display: inline-block;
      text-align: center;
    }
  }

  .toc-child {
    transform: scaleY(0);
    height: 0;
    overflow: hidden;
    transition: 0.3s;
    transform-origin: top;

    >.toc-item:last-child {
      margin-bottom: 0;
    }
  }

  .active>.toc-child, .current>.toc-child {
    height: auto;
    transform: scaleY(1);
  }

  .active>a, .current>a, .active>a>span, .current>a>span {
    color: var(--red-0);
    opacity: 1;
  }
}

.toc-title {
  letter-spacing: 2px;
  color: var(--grey-9);
  line-height: 1em;
  font-weight: bold;
  padding: 10px 0 12px;
}

.toc-item {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sidebar-btn-wrapper {
  display: flex;
  justify-content: center;
  gap: 14px;
  padding: 12px 0 2px;

  .sidebar-toc-btn, .sidebar-common-btn {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 46px;
    height: 46px;
    background: linear-gradient(135deg, unquote('color-mix(in srgb, var(--red-6) 92%, transparent)'), unquote('color-mix(in srgb, var(--color-background) 70%, transparent)'));
    color: var(--red-1);
    font-weight: 700;
    box-shadow: 0 12px 24px unquote('color-mix(in srgb, var(--color-red-3-shadow) 22%, transparent)');
    border-radius: 16px;
    margin: 0;
    transition: 0.3s;
    will-change: transform;
    border: 1px solid unquote('color-mix(in srgb, var(--red-3) 18%, transparent)');

    &:hover {
      transform: translateY(-2px) scale(1.03);
    }

    [data-theme='dark'] & {
      filter: brightness(0.92);
    }
  }

  .current {
    background: linear-gradient(135deg, var(--red-1), var(--red-2));
    color: var(--glass-card-title);
    box-shadow: 0 14px 28px unquote('color-mix(in srgb, var(--color-red-3-shadow) 38%, transparent)');
  }
}

.sidebar-common-sidebar {
  display: flex;
  flex-direction: column;
  width: 100%;
  align-items: center;
  overflow-y: auto;
  flex: 1;
  min-height: 0;
  padding: 0 0 18px;
  gap: 8px;

  &::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
}

.sidebar-toc-sidebar {
  width: 100%;
  flex: 1;
  min-height: 0;
  padding: 12px 18px 18px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}