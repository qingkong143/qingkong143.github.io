@keyframes sidebar-shine {
  0% {
    background-position: 0;
  }

  60% {
    background-position: 220px;
  }

  100% {
    background-position: 220px;
  }
}

.sidebar-left, .sidebar-right {
  #sidebar {
    display: block;

    @media mg-large {
      display: none;
    }

    @media mq-large {
      width: 23%;
      min-width: 268px;
      margin: 0 16px;
      height: inherit;
    }
  }
}

[data-theme='dark'] .sidebar-wrap {
  box-shadow: var(--shadow-card);
}

[data-theme='dark'] #mobile-nav .sidebar-wrap {
  box-shadow: 0 0 0 0;
}

.sidebar-wrapper-container {
  display: flex;
  flex-direction: column;

  &.sticky {
    max-height: calc(100vh - 40px);
    position: sticky;
    top: 20px;
  }
}

.sidebar-wrapper {
  transition: 0.3s;
  flex: 1;
  min-height: 0;
  display: flex;
  position: relative;
  color: white;
  font-family: font-basic;

  &:before, &:after {
    content: '';
    position: absolute;
    pointer-events: none;
    background-color: #fab5704c;
  }

  &:before {
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    top: 30%;
    right: 7%;
    z-index: 0;
  }

  &:after {
    width: 0;
    height: 3rem;
    top: 8%;
    right: 5%;
    border-left: 1px solid rgba(255, 255, 255, 0.55);
    background: transparent;
    z-index: 0;
  }

  .aos-animate {
    transition-property: initial !important;

    &:hover {
      box-shadow: 0px 0px 20px 1px #ffbb763f;
      border-color: rgba(255, 255, 255, 0.454);
    }
  }
}

.sidebar-wrap {
  width: 100%;
  border-radius: 0.7rem;
  background-color: var(--glass-card-bg);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  transition: all ease 0.3s;
  interpolate-size: allow-keywords;
  flex: 1;
  min-height: 0;
  border: 1px solid rgba(255, 255, 255, 0.222);
  box-shadow: none;
  backdrop-filter: blur(var(--glass-card-blur)) saturate(var(--glass-card-saturate));
  -webkit-backdrop-filter: blur(var(--glass-card-blur)) saturate(var(--glass-card-saturate));
  position: relative;
  overflow: hidden;
  padding: 1rem 0 18px;
  color: white;
  z-index: 1;

  &:before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.08), rgba(255, 187, 118, 0.08) 48%, rgba(255, 255, 255, 0.03));
    opacity: 1;
  }

  > * {
    position: relative;
    z-index: 1;
  }

  &:hover {
    box-shadow: 0px 0px 20px 1px #ffbb763f;
    border-color: rgba(255, 255, 255, 0.454);
  }

  .hidden {
    display: none;
  }
}

.sidebar-author {
  display: flex;
  flex-shrink: 0;
  flex-direction: column;
  align-items: center;
  width: calc(100% - 32px);
  margin: 16px 16px 10px;
  padding: 28px 22px 20px;
  border-radius: 0.7rem;
  background-color: var(--glass-card-bg);
  box-sizing: border-box;
  border: 1px solid rgba(255, 255, 255, 0.222);
  box-shadow: none;
  backdrop-filter: blur(var(--glass-card-blur)) saturate(var(--glass-card-saturate));
  -webkit-backdrop-filter: blur(var(--glass-card-blur)) saturate(var(--glass-card-saturate));
  transition: all ease 0.3s;

  &:hover {
    box-shadow: 0px 0px 20px 1px #ffbb763f;
    border-color: rgba(255, 255, 255, 0.454);
  }

  img {
    display: block;
    min-width: 100px;
    min-height: 100px;
    width: 104px;
    height: 104px;
    border-radius: 32px;
    transition: opacity 0.3s;
    opacity: 0;
    object-fit: cover;
    margin: 0 0 18px;
    box-shadow: 0 16px 36px unquote('color-mix(in srgb, var(--color-red-6-shadow) 70%, transparent)');
    will-change: transform;
    transition: 0.3s;

    &:hover {
      transform: translateY(-2px) scale(1.03);
    }
  }

  img.lazyloaded {
    opacity: 1;
    animation: blur 0.8s forwards;
  }

  .sidebar-author-name {
    font-weight: var(--glass-card-font-weight);
    font-size: 2rem;
    color: var(--glass-card-title);
    margin: 0 0 12px;
    letter-spacing: 0.1em;
  }

  .sidebar-description {
    color: var(--glass-card-text);
    line-height: 1.7;
    text-align: center;
    padding: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    text-shadow: none;
    font-size: 0.9em;
    font-weight: var(--glass-card-font-weight);
    letter-spacing: 0.1em;
  }
}

.sidebar-state {
  display: flex;
  justify-content: center;
  width: calc(100% - 32px);
  margin: 0 16px 10px;
  padding: 4px 0 12px;
  color: var(--red-0);
  opacity: 0.96;
  transition: opacity 0.5s, color 0.5s;
  gap: 10px;

  &:hover {
    opacity: 1;
  }

    > div {
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    flex: 1;
    min-width: 0;
    padding: 14px 14px;
    border-radius: 0.7rem;
    background-color: var(--glass-card-bg);
    border: 1px solid rgba(255, 255, 255, 0.222);
    box-shadow: none;
    margin: 0;
    color: rgba(255, 255, 255, 0.86);
    transition: all ease 0.3s;

    &:hover {
      box-shadow: 0px 0px 20px 1px #ffbb763f;
      border-color: rgba(255, 255, 255, 0.454);
    }

    div {
      margin: 4px 0;
      letter-spacing: 0.1em;
    }
  }
}

.sidebar-state-article {
  border-right: none;
}

.sidebar-state-tag {
  border-left: none;
}

.sidebar-state-number {
  font-weight: 700;
  font-size: 22px;
}

.sidebar-social {
  display: flex;
  flex-shrink: 0;
  justify-content: center;
  width: calc(100% - 48px);
  flex-wrap: wrap;
  gap: 10px;
  margin: 4px 0 18px;

  div {
    position: relative;
    width: 44px;
    height: 44px;
    border-radius: 0.7rem;
    background-color: var(--glass-card-bg);
    border: 1px solid rgba(255, 255, 255, 0.222);
    box-shadow: none;
    transition: all ease 0.3s;

    &:hover {
      transform: translateY(-2px);
      box-shadow: 0px 0px 20px 1px #ffbb763f;
      border-color: rgba(255, 255, 255, 0.454);
    }

    a {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }
  }
}

.sidebar-social-icon {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 44px;
  height: 44px;

  if (hexo-config('icon_font')) {
    font: 20px font-icon;
  } else {
    font: 20px var(--font-icon);
  }

  transition: transform 0.2s;
  will-change: transform;

  &:hover {
    transform: scale(1.06);
  }
}

