.bangumi-page {
  display: flex;
  flex-direction: column;
  gap: 24px;
  margin-bottom: 24px;
}

.bangumi-hero, .bangumi-page-content, .bangumi-card, .bangumi-empty-inner {
  background-color: var(--glass-card-bg);
  border: 1px solid rgba(255, 255, 255, 0.222);
  box-shadow: none;
  backdrop-filter: blur(var(--glass-card-blur)) saturate(var(--glass-card-saturate));
  -webkit-backdrop-filter: blur(var(--glass-card-blur)) saturate(var(--glass-card-saturate));
}

.bangumi-hero {
  padding: 28px 30px;
  border-radius: post-radius;
  position: relative;
  overflow: hidden;

  &:before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.1), rgba(255, 187, 118, 0.1) 48%, rgba(255, 255, 255, 0.04));
    pointer-events: none;
  }
}

.bangumi-hero-text {
  position: relative;
  z-index: 1;
}

.bangumi-hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 18px;

  span {
    padding: 8px 12px;
    border-radius: 999px;
    background: var(--glass-card-bg);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.222);
    color: #fff;
    font-size: 13px;
  }

  strong {
    color: #fff;
    font-size: 15px;
  }
}

.bangumi-eyebrow {
  margin: 0 0 10px;
  color: var(--red-1);
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.bangumi-title {
  margin: 0;
  color: #fff;
}

.bangumi-subtitle {
  margin: 12px 0 0;
  color: #fff;
  font-size: 18px;
}

.bangumi-description {
  margin-top: 16px;
  color: #fff;
  line-height: 1.8;
}

.bangumi-page-content {
  border-radius: post-radius;
  padding: article-padding;
}

.bangumi-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20px;

  @media mg-normal {
    grid-template-columns: 1fr;
  }
}

.bangumi-card {
  display: flex;
  gap: 12px;
  padding: 14px;
  border-radius: post-radius;
  transition: transform 0.3s, box-shadow 0.3s;

  &:hover {
    transform: translateY(-3px);
    box-shadow: 0px 0px 20px 1px #ffbb763f;
    border-color: rgba(255, 255, 255, 0.454);
  }

  @media mg-normal {
    flex-direction: column;
  }
}

.bangumi-cover-wrap {
  width: 112px;
  flex-shrink: 0;

  @media mg-normal {
    width: 100%;
  }
}

.bangumi-cover {
  display: block;
  width: 100%;
  aspect-ratio: 3 / 4;
  object-fit: cover;
  border-radius: 18px;
  box-shadow: var(--shadow-card);
}

.bangumi-card-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.bangumi-title-group {
  min-width: 0;
}

.bangumi-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.bangumi-card-title {
  margin: 0;
  color: #fff;
  font-size: 18px;
}

.bangumi-status {
  flex-shrink: 0;
  padding: 6px 12px;
  border-radius: 999px;
  background: linear-gradient(135deg, var(--red-1), var(--red-2));
  color: #fff;
  font-size: 13px;
  box-shadow: var(--shadow-red-6-shadow);
}

.bangumi-origin-title {
  margin-top: 8px;
  color: #fff;
  font-size: 14px;
  letter-spacing: 0.03em;
}

.bangumi-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 14px;

  span {
    padding: 6px 10px;
    border-radius: 999px;
    background: unquote('color-mix(in srgb, var(--color-background) 45%, transparent)');
    box-shadow: inset 0 0 0 1px unquote('color-mix(in srgb, var(--red-3) 18%, transparent)');
    color: #fff;
    font-size: 13px;
  }
}

.bangumi-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 14px;

  span {
    padding: 5px 10px;
    border-radius: 999px;
    background: unquote('color-mix(in srgb, var(--red-5) 78%, transparent)');
    color: #fff;
    font-size: 13px;
  }
}

.bangumi-summary {
  margin: 12px 0 0;
  color: #fff;
  line-height: 1.65;
  flex: 1;
}

.bangumi-card-footer {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 14px;
  margin-top: 12px;

  @media mg-normal {
    flex-direction: column;
    align-items: stretch;
  }
}

.bangumi-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8px 12px;
  border-radius: 12px;
  color: #fff !important;
  text-decoration: none;
  white-space: nowrap;
  background: linear-gradient(135deg, var(--red-1), var(--red-2));
  box-shadow: var(--shadow-red-6-shadow);
  transition: transform 0.25s, box-shadow 0.25s;

  &:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 28px unquote('color-mix(in srgb, var(--color-red-6-shadow) 46%, transparent)');
  }
}

.bangumi-empty-inner {
  border-radius: post-radius;
  padding: 28px 24px;
  color: var(--grey-8);
  text-align: center;
  line-height: 1.8;
}
