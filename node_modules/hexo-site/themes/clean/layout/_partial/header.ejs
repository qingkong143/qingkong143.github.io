<div id="header-nav">
  <nav id="main-nav" aria-label="Primary navigation">
    <%_ if (!Array.isArray(theme.menu)) { _%>
      <%_ for (let i in theme.menu) { _%>
        <a class="main-nav-link-wrap" href="<%- url_for_lang(theme.menu[i]) %>">
          <div class="main-nav-icon icon-taichi"></div>
          <span class="main-nav-link"><%= __(i) %></span>
        </span>
      <%_ } _%>
    <%_ } else { _%>
      <%_ for (let item of theme.menu) { _%>
        <a class="main-nav-link-wrap" href="<%- url_for_lang(item.url) %>">
          <div class="main-nav-icon icon <%= (item.icon === 'e62b' && theme.icon_font) || (item.icon === 'f6ad' && !theme.icon_font) || !item.icon ? 'rotate' : '' %>">
             <%_ if (item.icon) { _%>
              <%_ if (item.icon.includes('/') && item.icon.includes('.')) { _%>
                <img src="<%- url_for(item.icon, {relative: false}) %>" alt="<%= item.name %> icon" style="height: 1em;">
              <%_ } else { _%>
                <%- `&#x${item.icon};` %>
              <%_ } _%>
             <%_ } else { _%>
              <%- theme.icon_font ? '&#xe62b;' : '&#xf6ad;' %>
             <%_ } _%>
          </div>
          <span class="main-nav-link"><%= __(item.name) %></span>
        </span>
      <%_ } _%>
    <%_ } _%>
    <a id="main-nav-toggle" class="nav-icon" aria-label="Toggle navigation" role="button"></a>
  </nav>
  <nav id="sub-nav" aria-label="Secondary navigation">
    <%_ const hasFeed = config.feed || theme.rss; _%>
    <%_ if (hasFeed) { _%>
      <%- feed_tag().replace('<link rel="alternate" ', `<a id="nav-rss-link" class="nav-icon" title="${__('rss_feed')}" aria-label="${__('rss_feed')}" target="_blank" `).replace(' type="application/atom+xml">', '></a>').replace(' type="application/rss+xml">', '></a>') %>
    <%_ } _%>
    <%_ if (theme.algolia_search.enable || theme.generator_search.enable) { _%>
      <a id="nav-search-btn" class="nav-icon popup-trigger" title="<%= __('search') %>" aria-label="<%= __('search') %>"></a>
    <%_ } _%>
    <%_ if (theme.dark_mode.enable !== false) { _%>
      <label class="dark-mode-switch" for="dark-mode-switch" aria-label="Theme mode switch">
        <input id="dark-mode-switch" class="dark-mode-switch-input" type="checkbox">
        <span class="dark-mode-switch-box" aria-hidden="true"></span>
        <svg class="dark-mode-icon dark-mode-icon-moon" viewBox="0 0 100 100" aria-hidden="true">
          <path d="M82.1,61.2a31.9,31.9,0,0,1-12.4,2.4A33.3,33.3,0,0,1,36.4,30.3a31.9,31.9,0,0,1,2.4-12.4A33.3,33.3,0,1,0,82.1,61.2Z"></path>
        </svg>
        <svg class="dark-mode-icon dark-mode-icon-sun" viewBox="0 0 100 100" aria-hidden="true">
          <path d="M50,18v3.6m0,56.8V82M82,50H78.4M21.6,50H18M72.6,72.6l-2.5-2.5M29.9,29.9l-2.5-2.5m45.2,0-2.5,2.5M29.9,70.1l-2.5,2.5M64.2,50A14.2,14.2,0,1,1,50,35.8,14.3,14.3,0,0,1,64.2,50Z"></path>
        </svg>
      </label>
    <%_ } _%>
  </nav>
  <%_ if (theme.i18n.enable) { _%>
    <%_ let i18nMap = {
      'en': 'English',
      'zh-CN': '简体中文',
      'zh-TW': '正體中文',
      'ja': '日本語',
      'pt-BR': 'Português Brasileiro'
    } _%>
    <nav id="i18n-nav" aria-label="Language selection">
      <div class="custom-dropdown">
        <div class="select-selected" id="select-selected" role="button" aria-haspopup="listbox" aria-expanded="false" aria-label="Language menu">
          <span id="nav-language-btn" class="nav-icon" style="padding: 0 20px 0 0"></span>
          <span id="selected-lang"><%= i18nMap[post.lang] %></span>
        </div>
        <ul class="select-items" id="select-items" role="listbox" aria-label="Languages">
          <%_ for (let i of get_langs()) { _%>
            <li data-value="<%= i %>" role="option" <% if (post.lang === i) { %>class="selected" aria-selected="true"<% } else { %>aria-selected="false"<% } %>><%= i18nMap[i] %></li>
          <%_ } _%>
        </ul>
      </div>
      <script>
        var selectSelected = document.getElementById("select-selected");
        var selectedLang = document.getElementById("selected-lang");
        var selectItems = document.getElementById("select-items");
        var selectOptions = selectItems.querySelectorAll("li");

        selectSelected.addEventListener("click", () => {
          selectItems.classList.toggle("show");
          var expanded = selectSelected.getAttribute("aria-expanded") === "true";
          selectSelected.setAttribute("aria-expanded", (!expanded).toString());
        });

        selectOptions.forEach((item) => {
          item.addEventListener("click", () => {
            const langMap = {};
            <%_ for (let i of get_langs()) { _%>
              langMap['<%= i %>'] = '<%= switch_lang(i) %>';
            <%_ } _%>
            selectedLang.textContent = item.textContent;
            selectItems.classList.remove("show");
            selectOptions.forEach((option) => {
              option.classList.remove("selected");
            });
            item.classList.add("selected");
            window.location = langMap[item.dataset.value];
          });
        });

        document.addEventListener("click", (event) => {
          if (!event.target.closest(".custom-dropdown")) {
            selectItems.classList.remove("show");
            selectSelected.setAttribute("aria-expanded", "false");
          }
        });
      </script>
    </nav>
  <%_ } _%>
  <%_ if (theme.triangle_badge.enable) { _%>
  <a href="<%= theme.triangle_badge.link %>" class="triangle-badge" title="<%= theme.triangle_badge.icon %>" target="_blank" rel="noopener nofollow noreferrer">
    <div class="icon icon-<%= theme.triangle_badge.icon %> triangle-badge-icon"></div>
  </a>
  <%_ } _%>
</div>
<%_
  const headerHeroImage = theme.header_hero && typeof theme.header_hero.image === 'string' && theme.header_hero.image
    ? url_for(theme.header_hero.image, {relative: false})
    : '';
  const useSharedHeroBackground = typeof sharedHeroBackground === 'string' && sharedHeroBackground;
  const headerCoverImage = page.cover && typeof page.cover === 'string' && !page.cover.startsWith('rgb') ? url_for(page.cover, {relative: false}) : '';
  const headerThemeCoverImage = is_post() && theme.cover && typeof theme.cover === 'string' && theme.cover !== false && !theme.cover.startsWith('rgb') ? url_for(theme.cover, {relative: false}) : '';
  const headerBannerImage = theme.banner ? url_for(theme.banner, {relative: false}) : '';
  const resolvedHeaderImage = headerHeroImage || headerCoverImage || headerThemeCoverImage || useSharedHeroBackground || headerBannerImage;
_%>
<%_
  const pageTitle = post.type == '404'
    ? __('not_found.title')
    : is_archive()
      ? __('archives')
      : is_category()
        ? __('categories')
        : is_tag()
          ? __('tags')
          : post.title
            ? post.title
            : config.title;
  let pageSubtitle = null;
  if (post.type == 404) {
    pageSubtitle = __('not_found.subtitle');
  } else if (is_archive()) {
    if (is_month()) {
      pageSubtitle = page.year + '/' + page.month;
    } else if (is_year()) {
      pageSubtitle = page.year;
    }
  } else if (is_category()) {
    pageSubtitle = post.category;
  } else if (is_tag()) {
    pageSubtitle = post.tag;
  } else if (post.title) {
    if (theme.summary.enable && theme.summary.style === 'subtitle' && post.excerpt) {
      pageSubtitle = stripHtml(post.excerpt);
    }
  } else if (theme.subtitle || config.subtitle) {
    pageSubtitle = theme.subtitle || config.subtitle;
  }
  const showHeaderOuter = is_home();
_%>
<header id="header" aria-label="Site header" class="<%= showHeaderOuter ? 'header-home' : 'header-post' %>">
  <%_ if (showHeaderOuter) { _%>
  <div id="header-outer" class="container-wrap">
    <div id="header-title">
      <%_ if (pageTitle) { _%>
        <%_ if (post.type == '404') { _%>
          <a href="/" id="logo">
            <h1 data-aos="<%= theme.animation.options.header.title %>"><%= pageTitle %></h1>
          </a>
        <%_ } else { _%>
          <span id="logo">
            <h1 data-aos="<%= theme.animation.options.header.title %>"><%= pageTitle %></h1>
          </span>
        <%_ } _%>
      <%_ } _%>
      <h2 id="subtitle-wrap" data-aos="<%= theme.animation.options.header.subTitle %>">
        <%_ if (pageSubtitle) { _%>
          <%_ if (post.type == 404) { _%>
            <a href="/" id="subtitle"><%= pageSubtitle %></a>
          <%_ } else { _%>
            <span id="subtitle"><%= pageSubtitle %></span>
          <%_ } _%>
        <%_ } _%>
      </h2>
    </div>
  </div>
  <%_ } _%>
</header>
