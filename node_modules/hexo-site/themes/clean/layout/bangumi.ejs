<article class="bangumi-page" data-aos="<%= theme.animation.options.article.whole %>">
  <header class="bangumi-hero">
    <div class="bangumi-hero-text">
      <p class="bangumi-eyebrow"><%= __('bangumi') %></p>
      <h1 class="bangumi-title"><%= page.title || theme.bangumi.title || __('bangumi') %></h1>
      <%_ if (theme.bangumi.subtitle) { _%>
        <p class="bangumi-subtitle"><%= theme.bangumi.subtitle %></p>
      <%_ } _%>
      <%_ if (theme.bangumi.description) { _%>
        <div class="bangumi-description"><%= theme.bangumi.description %></div>
      <%_ } _%>
      <%_
        const pageBangumiItems = Array.isArray(page.bangumi_items) ? page.bangumi_items : [];
        const pageBangumi = Array.isArray(page.bangumi) ? page.bangumi : [];
        const bangumiItems = pageBangumiItems.length ? pageBangumiItems : pageBangumi;
      _%>
      <%_ if (bangumiItems.length) { _%>
        <div class="bangumi-hero-meta">
          <span><strong><%= bangumiItems.length %></strong> 部收藏</span>
          <span>持续更新中</span>
        </div>
      <%_ } _%>
    </div>
  </header>

  <%_ if (page.content) { _%>
    <section class="bangumi-page-content article-entry">
      <%- page.content %>
    </section>
  <%_ } _%>

  <%_ if (bangumiItems.length) { _%>
    <section class="bangumi-grid" aria-label="Bangumi list">
      <%_ bangumiItems.forEach((item) => { _%>
        <article class="bangumi-card">
          <%_ if (item.cover) { _%>
            <%_ const isExternalCover = /^https?:\/\//i.test(item.cover || ''); _%>
            <div class="bangumi-cover-wrap">
              <img class="bangumi-cover" src="<%- isExternalCover ? item.cover : url_for(item.cover, {relative: false}) %>" alt="<%= item.title || '' %>">
            </div>
          <%_ } _%>
          <div class="bangumi-card-body">
            <div class="bangumi-card-header">
              <div class="bangumi-title-group">
                <h2 class="bangumi-card-title"><%= item.title || '' %></h2>
                <%_ if (item.origin_title) { _%>
                  <div class="bangumi-origin-title"><%= item.origin_title %></div>
                <%_ } _%>
              </div>
              <%_ if (item.status) { _%>
                <span class="bangumi-status"><%= item.status %></span>
              <%_ } _%>
            </div>
            <%_ if (item.rating || item.episodes || item.year) { _%>
              <div class="bangumi-meta">
                <%_ if (item.rating) { _%><span>评分 <strong><%= item.rating %></strong></span><%_ } _%>
                <%_ if (item.episodes) { _%><span><%= item.episodes %></span><%_ } _%>
                <%_ if (item.year) { _%><span><%= item.year %> 年</span><%_ } _%>
              </div>
            <%_ } _%>
            <%_ if (item.tags && item.tags.length) { _%>
              <div class="bangumi-tags">
                <%_ item.tags.forEach((tag) => { _%>
                  <span><%= tag %></span>
                <%_ }) _%>
              </div>
            <%_ } _%>
            <%_ if (item.summary) { _%>
              <p class="bangumi-summary"><%= item.summary %></p>
            <%_ } _%>
            <div class="bangumi-card-footer">
              <%_ if (item.url) { _%>
                <a class="bangumi-link" href="<%- url_for(item.url, {relative: false}) %>" target="_blank" rel="noopener noreferrer">查看条目</a>
              <%_ } _%>
            </div>
          </div>
        </article>
      <%_ }) _%>
    </section>
  <%_ } else { _%>
    <section class="bangumi-empty">
      <div class="bangumi-empty-inner">这里还没有追番条目。你可以先在页面 front-matter 里补充 `bangumi` 列表，再把这一页慢慢填成自己的收藏清单。</div>
    </section>
  <%_ } _%>
</article>

