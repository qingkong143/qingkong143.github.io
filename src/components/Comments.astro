---
import { siteConfig } from '../data/site';
---
{siteConfig.comments.twikoo.enable && (
  <section id="comments">
    <div class="comment-header">
      <h2 class="comment-title">说些什么吧！</h2>
    </div>
    <div class="twikoo-comment"></div>
    <script is:inline define:vars={{ envId: siteConfig.comments.twikoo.envId, region: siteConfig.comments.twikoo.region, src: siteConfig.comments.twikoo.src, integrity: siteConfig.comments.twikoo.integrity }}>
      (() => {
        const getTwikooStyles = (root = document) => Array.from(root.querySelectorAll('style'))
          .filter((style) => /\.tk-|\.twikoo|\.el-|OwO/.test(style.textContent || ''));

        const nextTwikooStyleId = () => {
          window.__twikooStylePersistIndex = window.__twikooStylePersistIndex || 0;
          const id = `twikoo-style-${window.__twikooStylePersistIndex}`;
          window.__twikooStylePersistIndex += 1;
          return id;
        };

        const persistTwikooStyles = () => {
          getTwikooStyles(document.head).forEach((style) => {
            if (!style.hasAttribute('data-astro-transition-persist')) {
              style.setAttribute('data-astro-transition-persist', nextTwikooStyleId());
            }
          });
        };

        const queuePersistTwikooStyles = () => {
          requestAnimationFrame(persistTwikooStyles);
          window.setTimeout(persistTwikooStyles, 100);
        };

        if (!window.__twikooStyleObserver) {
          window.__twikooStyleObserver = new MutationObserver(queuePersistTwikooStyles);
          window.__twikooStyleObserver.observe(document.head, { childList: true, subtree: true, characterData: true });
        }

        const loadTwikoo = () => new Promise((resolve, reject) => {
          if (window.twikoo) {
            resolve();
            return;
          }

          const existing = document.querySelector(`script[src="${src}"]`);
          if (existing) {
            if (existing.dataset.loaded === 'true' || window.twikoo) {
              existing.dataset.loaded = 'true';
              resolve();
              return;
            }
            existing.addEventListener('load', () => {
              existing.dataset.loaded = 'true';
              resolve();
            }, { once: true });
            existing.addEventListener('error', reject, { once: true });
            return;
          }

          const script = document.createElement('script');
          script.src = src;
          script.integrity = integrity;
          script.crossOrigin = 'anonymous';
          script.dataset.loaded = 'false';
          script.addEventListener('load', () => {
            script.dataset.loaded = 'true';
            resolve();
          }, { once: true });
          script.addEventListener('error', reject, { once: true });
          document.head.appendChild(script);
        });

        const initTwikoo = () => {
          const container = document.querySelector('.twikoo-comment');
          if (!container || container.dataset.initialized === 'true') return;
          loadTwikoo()
            .then(() => {
              if (!window.twikoo || !document.body.contains(container)) return;
              window.twikoo.init({
                envId,
                el: '.twikoo-comment',
                region,
                lang: document.documentElement.lang || 'zh-CN'
              });
              container.dataset.initialized = 'true';
              requestAnimationFrame(() => {
                persistTwikooStyles();
                window.setTimeout(persistTwikooStyles, 200);
              });
            })
            .catch(() => {});
        };

        initTwikoo();
        document.addEventListener('astro:page-load', initTwikoo);
        document.addEventListener('astro:before-swap', (event) => {
          persistTwikooStyles();
          getTwikooStyles(document.head).forEach((style) => {
            const id = style.getAttribute('data-astro-transition-persist');
            if (id && !event.newDocument.head.querySelector(`[data-astro-transition-persist="${id}"]`)) {
              event.newDocument.head.appendChild(style.cloneNode(true));
            }
          });
        });
      })();
    </script>
  </section>
)}
