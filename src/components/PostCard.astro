---
import { siteConfig } from '../data/site';
import { getImageSrcset, getProxiedImage, withBase } from '../utils/paths';
import { getPostPath } from '../utils/posts';
import type { PostPathMap } from '../utils/posts';

interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      date?: Date;
      cover?: string;
      brief?: string;
      summary?: string;
      description?: string;
    };
    body?: string;
  };
  index: number;
  postPathMap?: PostPathMap;
}

const { post, index, postPathMap } = Astro.props;
const manualSummary = post.data.brief || post.data.summary || post.data.description;
const autoSummary = siteConfig.postcard === 'enable' ? post.body?.replace(/<[^>]*>/g, '').slice(0, 160) : '';
const summary = manualSummary || autoSummary;
const hasSummary = Boolean(summary);
const summaryOnly = Boolean(manualSummary && !autoSummary);
const rawCover = post.data.cover || siteConfig.defaultCover;
const cover = getProxiedImage(rawCover, { width: 520, height: 302, fit: 'cover', quality: 82 });
const coverSrcset = getImageSrcset(rawCover, [360, 520, 720], { width: 520, height: 302, fit: 'cover', quality: 82 });
const isPriorityCover = index === 0;
const href = withBase(getPostPath(post, postPathMap));
---
<div class="post-wrapper">
  <article class:list={['post-wrap', index % 2 === 0 ? 'left' : 'right']}>
    <a class="post-link" href={href} aria-label={post.data.title}></a>
    <div class:list={['post-cover', index % 2 === 0 ? 'left' : 'right']}>
      <img
        src={cover}
        srcset={coverSrcset}
        sizes="(max-width: 767px) calc(100vw - 32px), 318px"
        alt={post.data.title}
        loading={isPriorityCover ? 'eager' : 'lazy'}
        fetchpriority={isPriorityCover ? 'high' : 'auto'}
        decoding="async"
        referrerpolicy="no-referrer"
      />
    </div>
    <div class:list={['post-info', summaryOnly && 'summary-only', !hasSummary && 'title-only']}>
      <div class="post-meta">
        {post.data.date && <span>{post.data.date.toLocaleDateString('zh-CN')}</span>}
      </div>
      <h2 class="post-title">{post.data.title}</h2>
      {summary && <div class="post-brief">{summary}</div>}
    </div>
  </article>
</div>
