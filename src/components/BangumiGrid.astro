---
import { getImageSrcset, getProxiedImage } from '../utils/paths';

interface Item {
  title: string;
  type?: string;
  area?: string;
  cover?: string;
  coverSrcset?: string;
  totalCount?: string;
  id?: number;
  score?: number;
  des?: string;
  status?: string;
}

const statusMap = {
  wantWatch: '想看',
  watching: '在看',
  watched: '看过'
};

const normalizeCover = (cover?: string) => cover
  ? getProxiedImage(cover, { width: 440, height: 275, fit: 'cover', quality: 82 })
  : cover;

const getCoverSrcset = (cover?: string) => cover
  ? getImageSrcset(cover, [320, 440, 640], { width: 440, height: 275, fit: 'cover', quality: 82 })
  : undefined;

const getBangumiUrl = (item: Item) => item.id ? `https://www.bilibili.com/bangumi/media/md${item.id}/` : undefined;

const bangumis = Astro.props.bangumis as Record<keyof typeof statusMap, Item[]>;
const items = Object.entries(statusMap).flatMap(([key, label]) =>
  (bangumis[key as keyof typeof statusMap] || []).map((item) => ({ ...item, status: label, cover: normalizeCover(item.cover), coverSrcset: getCoverSrcset(item.cover) }))
);
---
<section class="bangumi-page">
  <header class="bangumi-hero">
    <h1 class="bangumi-title">追番</h1>
    <p class="bangumi-subtitle">把喜欢的作品、补番进度和观后感收进同一页。</p>
    <div class="bangumi-description">生命不息，追番不止！</div>
    <div class="bangumi-hero-meta"><span><strong>{items.length}</strong> 部收藏</span><span>持续更新中</span></div>
  </header>
  <div class="bangumi-grid">
    {items.map((item) => (
      <article class="bangumi-card">
        {item.cover && <img class="bangumi-cover" src={item.cover} srcset={item.coverSrcset} sizes="(max-width: 767px) calc(100vw - 32px), 260px" alt={item.title} loading="lazy" decoding="async" />}
        <div class="bangumi-card-body">
          <div class="bangumi-card-header">
            <h2 class="bangumi-card-title">
              {getBangumiUrl(item) ? (
                <a href={getBangumiUrl(item)} target="_blank" rel="noopener noreferrer">{item.title}</a>
              ) : item.title}
            </h2>
            <span class="bangumi-status">{item.status}</span>
          </div>
          <div class="bangumi-meta">
            {item.score && <span>评分 <strong>{item.score}</strong></span>}
            {item.totalCount && <span>{item.totalCount}</span>}
          </div>
          <div class="bangumi-tags">
            {item.type && <span>{item.type}</span>}
            {item.area && <span>{item.area}</span>}
          </div>
          {item.des && <p class="bangumi-summary">{item.des}</p>}
        </div>
      </article>
    ))}
  </div>
</section>
