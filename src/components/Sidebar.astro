---
import { getCollection } from 'astro:content';
import { siteConfig } from '../data/site';
import { withBase } from '../utils/paths';

const posts = await getCollection('blog');
const categories = new Set(posts.flatMap((post) => {
  const value = post.data.categories;
  if (!value) return [];
  return Array.isArray(value) ? value : [value];
}));
const tags = new Set(posts.flatMap((post) => {
  const value = post.data.tags;
  if (!value) return [];
  return Array.isArray(value) ? value : [value];
}));
---
<aside id="sidebar" aria-label="侧栏">
  <div class="sidebar-wrapper-container sticky">
    <div class="sidebar-wrap">
      <div class="sidebar-author">
        <img src={withBase(siteConfig.avatar)} alt={siteConfig.author} loading="lazy" />
        <div class="sidebar-author-name">{siteConfig.author}</div>
        <div class="sidebar-description">{siteConfig.subtitle}</div>
      </div>
      <div class="sidebar-state">
        <div>
          <span>文章</span>
          <strong>{posts.length}</strong>
        </div>
        <div>
          <span>分类</span>
          <strong>{categories.size}</strong>
        </div>
        <div>
          <span>标签</span>
          <strong>{tags.size}</strong>
        </div>
      </div>
      <div class="sidebar-social" aria-label="社交链接">
        {siteConfig.social.map((item) => (
          <a class={`sidebar-social-icon icon-${item.name}`} href={item.href} target={item.href.startsWith('mailto:') ? undefined : '_blank'} rel={item.href.startsWith('mailto:') ? undefined : 'noopener noreferrer nofollow'} aria-label={item.label}>{item.label}</a>
        ))}
      </div>
      <nav class="sidebar-menu" aria-label="侧栏导航">
        {siteConfig.nav.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
      </nav>
    </div>
    <div class="sidebar-widget">
      <section class="sidebar-widget-card">
        <h2>分类</h2>
        <div class="sidebar-chip-list">
          {[...categories].map((category) => <a href={withBase(`/categories/${encodeURIComponent(category)}/`)}>{category}</a>)}
        </div>
      </section>
      <section class="sidebar-widget-card">
        <h2>标签</h2>
        <div class="sidebar-chip-list">
          {[...tags].map((tag) => <a href={withBase(`/tags/${encodeURIComponent(tag)}/`)}>{tag}</a>)}
        </div>
      </section>
    </div>
  </div>
</aside>
