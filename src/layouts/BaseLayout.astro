---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import Player from '../components/Player.astro';
import { siteConfig } from '../data/site';
import { withBase } from '../utils/paths';

const { title = siteConfig.title, description = siteConfig.description, sidebar = true, mainClass = '' } = Astro.props;
const searchConfig = siteConfig.search;
const searchIndexUrl = withBase('/search-index.json');
const globalBackground = siteConfig.globalBackground;
const globalBackgroundImage = withBase(globalBackground.image);
const globalBackgroundPreload = globalBackground.enable ? globalBackgroundImage : undefined;
const bodyStyle = globalBackground.enable
  ? `--global-bg-image: url('${globalBackgroundImage}'); --global-bg-opacity: ${globalBackground.opacity}; --global-bg-blur: ${globalBackground.blur}px; --global-bg-attachment: ${globalBackground.attachment};`
  : '--global-bg-image: none; --global-bg-opacity: 0; --global-bg-blur: 0px; --global-bg-attachment: scroll;';
---
<!doctype html>
<html lang="zh-CN" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {globalBackgroundPreload && <link rel="preload" href={globalBackgroundPreload} as="image" fetchpriority="high" />}
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body style={bodyStyle}>
    <div class="site-shell">
      <header id="header-nav">
        <nav class="nav-inner" aria-label="站点导航">
          <a class="site-name" href={withBase('/')}>{siteConfig.title}</a>
          <div class="main-nav">
            {siteConfig.nav.map((item) => <a class="main-nav-link" href={withBase(item.href)}>{item.label}</a>)}
          </div>
          <div class="nav-controls">
            {searchConfig.enable && (
              <button id="search-toggle" class="nav-control-button" type="button" aria-label={searchConfig.buttonLabel} aria-controls="search-panel" aria-expanded="false">
                <svg viewBox="0 0 100 100" aria-hidden="true"><path d="M44 72a28 28 0 1 1 19.8-8.2L82 82M64 64l18 18" /></svg>
              </button>
            )}
            <button id="theme-toggle" class="dark-mode-switch" type="button" aria-label="切换暗色模式">
              <svg class="dark-mode-icon dark-mode-icon-sun" viewBox="0 0 100 100" aria-hidden="true"><path d="M50 18v8m0 48v8M82 50h-8M26 50h-8m54.6 22.6-5.7-5.7M33.1 33.1l-5.7-5.7m45.2 0-5.7 5.7M33.1 66.9l-5.7 5.7M64.2 50A14.2 14.2 0 1 1 50 35.8 14.3 14.3 0 0 1 64.2 50Z" /></svg>
              <svg class="dark-mode-icon dark-mode-icon-moon" viewBox="0 0 100 100" aria-hidden="true"><path d="M82.1 61.2a31.9 31.9 0 0 1-12.4 2.4A33.3 33.3 0 0 1 36.4 30.3a31.9 31.9 0 0 1 2.4-12.4A33.3 33.3 0 1 0 82.1 61.2Z" /></svg>
            </button>
          </div>
        </nav>
        {searchConfig.enable && (
          <div id="search-panel" class="search-panel" aria-hidden="true">
            <div class="search-box">
              <label class="search-label" for="search-input">{searchConfig.label}</label>
              <input id="search-input" class="search-input" type="search" placeholder={searchConfig.placeholder} autocomplete="off" />
              <div id="search-results" class="search-results" role="list"></div>
            </div>
          </div>
        )}
      </header>
      <main id="main" class:list={[sidebar && 'has-sidebar', mainClass]}>
        {sidebar ? (
          <>
            <div class="content-column">
              <slot />
            </div>
            <div class="sidebar-column"><Sidebar /><Player /></div>
          </>
        ) : (
          <slot />
        )}
      </main>
      <footer id="footer">
        <div class="footer-line"></div>
        <p>© 2021-2026 {siteConfig.author}. Powered by Astro.</p>
      </footer>
    </div>
    <div id="page-transition-loader" aria-hidden="true">
      <div class="page-transition-card">
        <span class="page-transition-spinner"></span>
        <span>页面加载中</span>
      </div>
    </div>
    <script is:inline define:vars={{ searchConfig, searchIndexUrl }}>
      (() => {
        window.__astroCleanPageLoader = window.__astroCleanPageLoader || { timer: 0, startedAt: 0 };
        window.__astroCleanSearch = window.__astroCleanSearch || { posts: null, promise: null };
      const pageLoaderState = window.__astroCleanPageLoader;
      const searchState = window.__astroCleanSearch;

      const setTheme = () => {
        document.documentElement.dataset.theme = localStorage.getItem('theme') || 'light';
      };

      const showPageLoader = () => {
        window.clearTimeout(pageLoaderState.timer);
        pageLoaderState.startedAt = Date.now();
        document.documentElement.classList.add('is-page-transitioning');
      };

      const hidePageLoader = () => {
        const elapsed = Date.now() - pageLoaderState.startedAt;
        const delay = Math.max(0, 420 - elapsed);
        window.clearTimeout(pageLoaderState.timer);
        pageLoaderState.timer = window.setTimeout(() => {
          document.documentElement.classList.remove('is-page-transitioning');
        }, delay);
      };

      const closeSearch = () => {
        const searchToggle = document.querySelector('#search-toggle');
        const searchPanel = document.querySelector('#search-panel');
        searchPanel?.classList.remove('open');
        searchToggle?.setAttribute('aria-expanded', 'false');
        searchPanel?.setAttribute('aria-hidden', 'true');
      };

      const loadSearchPosts = async () => {
        if (searchState.posts) return searchState.posts;
        searchState.promise ||= fetch(searchIndexUrl)
          .then((response) => response.ok ? response.json() : [])
          .then((posts) => {
            searchState.posts = Array.isArray(posts) ? posts : [];
            return searchState.posts;
          })
          .catch(() => {
            searchState.posts = [];
            return searchState.posts;
          });
        return searchState.promise;
      };

      const setSearchEmpty = (message) => {
        const searchResults = document.querySelector('#search-results');
        if (!searchResults) return;
        const empty = document.createElement('div');
        empty.className = 'search-empty';
        empty.textContent = message;
        searchResults.replaceChildren(empty);
      };

      const renderResults = async (keyword) => {
        const searchResults = document.querySelector('#search-results');
        if (!searchResults) return;
        const value = keyword.trim().toLowerCase();
        if (!value) {
          setSearchEmpty(searchConfig.emptyText);
          return;
        }
        const searchPosts = await loadSearchPosts();
        const results = searchPosts.filter((post) => post.text.toLowerCase().includes(value)).slice(0, searchConfig.maxResults);
        if (!results.length) {
          setSearchEmpty(searchConfig.noResultsText);
          return;
        }
        searchResults.replaceChildren(...results.map((post) => {
          const link = document.createElement('a');
          const title = document.createElement('span');
          link.className = 'search-result';
          link.href = post.href;
          link.setAttribute('role', 'listitem');
          title.textContent = post.title;
          link.append(title);
          if (post.date) {
            const time = document.createElement('time');
            time.textContent = post.date;
            link.append(time);
          }
          return link;
        }));
      };

      const toggleSearch = () => {
        const searchToggle = document.querySelector('#search-toggle');
        const searchPanel = document.querySelector('#search-panel');
        const searchInput = document.querySelector('#search-input');
        if (!searchPanel) return;
        const opened = !searchPanel.classList.contains('open');
        searchPanel.classList.toggle('open', opened);
        searchToggle?.setAttribute('aria-expanded', String(opened));
        searchPanel.setAttribute('aria-hidden', String(!opened));
        if (opened) {
          renderResults(searchInput?.value || '');
          requestAnimationFrame(() => searchInput?.focus());
        }
      };

      setTheme();

      if (!window.__astroCleanLayoutBound) {
        window.__astroCleanLayoutBound = true;

        document.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          if (target.closest('#theme-toggle')) {
            const root = document.documentElement;
            const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
            root.dataset.theme = next;
            localStorage.setItem('theme', next);
            return;
          }

          if (target.closest('#search-toggle')) {
            toggleSearch();
            return;
          }

          const searchPanel = document.querySelector('#search-panel');
          const searchToggle = document.querySelector('#search-toggle');
          if (!searchPanel?.classList.contains('open')) return;
          if (searchPanel.contains(target) || searchToggle?.contains(target)) return;
          closeSearch();
        });

        document.addEventListener('input', (event) => {
          const target = event.target;
          if (target instanceof HTMLInputElement && target.matches('#search-input')) {
            renderResults(target.value);
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && document.querySelector('#search-panel')?.classList.contains('open')) {
            closeSearch();
          }
        });

        document.addEventListener('astro:before-preparation', () => {
          closeSearch();
          showPageLoader();
        });

        document.addEventListener('astro:before-swap', (event) => {
          event.newDocument.documentElement.dataset.theme = localStorage.getItem('theme') || 'light';
          event.newDocument.documentElement.classList.add('is-page-transitioning');
        });

        document.addEventListener('astro:after-swap', () => {
          setTheme();
          requestAnimationFrame(hidePageLoader);
        });

        document.addEventListener('astro:page-load', () => {
          setTheme();
          hidePageLoader();
        });
      }
      })();
    </script>
  </body>
</html>
