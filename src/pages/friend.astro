---
import BaseLayout from '../layouts/BaseLayout.astro';
import Comments from '../components/Comments.astro';
import { siteConfig } from '../data/site';
import { getImageSrcset, getProxiedImage } from '../utils/paths';

const friends = [
  {
    name: 'D-Sketon',
    url: 'https://d-sketon.github.io/',
    desc: '一个车万人',
    image: 'https://d-sketon.github.io/avatar/avatar.webp'
  }
];
---
<BaseLayout title={`友情链接 - ${siteConfig.title}`} description="友情链接">
  <article class="article">
    <div class="article-inner">
      <header class="article-header"><h1 class="article-title">友情链接</h1></header>
      <div class="hr-line"></div>
      <div class="article-entry">
        <h2>本站信息</h2>
        <ul>
          <li>站名：语焉</li>
          <li>站长：Torch</li>
          <li>地址：<a href="https://blog.318670.xyz">https://blog.318670.xyz</a></li>
        </ul>
        <h2>申请方法</h2>
        <p>添加本站后，在本页留言，格式如下：</p>
        <pre><code>- name: #您的名字
  url: #您的网址
  desc: #简短描述
  image: #一张图片</code></pre>
        <h2>小伙伴们</h2>
        <div class="friend-grid">
          {friends.map((friend) => (
            <a class="friend-card" href={friend.url} target="_blank" rel="noopener noreferrer">
              <img
                src={getProxiedImage(friend.image, { width: 116, height: 116, fit: 'cover', quality: 82 })}
                srcset={getImageSrcset(friend.image, [58, 116, 174], { width: 116, height: 116, fit: 'cover', quality: 82 })}
                sizes="58px"
                alt={friend.name}
                loading="lazy"
                decoding="async"
                referrerpolicy="no-referrer"
              />
              <span class="friend-name">{friend.name}</span>
              <span class="friend-desc">{friend.desc}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </article>
  <Comments />
</BaseLayout>
